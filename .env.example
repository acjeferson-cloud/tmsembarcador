# ⚠️ ATENÇÃO: Este é um arquivo de EXEMPLO
# NUNCA commite o arquivo .env com valores reais!
# Copie este arquivo para .env e preencha com seus valores

# Supabase Configuration
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_anonima_aqui

# Application URL (usado para links em emails NPS, rastreamento público, etc)
# Em desenvolvimento: deixe vazio ou use http://localhost:5173
# Em produção: use a URL completa (ex: https://app.logaxis.com.br)
VITE_APP_URL=

# Google Maps API
VITE_GOOGLE_MAPS_API_KEY=sua_chave_google_maps

# reCAPTCHA
VITE_RECAPTCHA_SITE_KEY=sua_site_key_recaptcha
RECAPTCHA_SECRET_KEY=sua_secret_key_recaptcha

# PRODUÇÃO: Use Google Cloud Secret Manager
# gcloud secrets create supabase-url --data-file=- < secret.txt
# gcloud secrets create supabase-anon-key --data-file=- < secret.txt
